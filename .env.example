NODE_ENV=development
APP_ENV=local

API_PORT=4000
API_URL=http://localhost:4000
DASHBOARD_URL=http://localhost:3000
TRUST_PROXY=false
COMPRESSION_ENABLED=true
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

DATABASE_URL=postgresql://responix:responix_dev_password@localhost:5432/responix?schema=public
POSTGRES_DB=responix
POSTGRES_USER=responix
POSTGRES_PASSWORD=responix_dev_password

REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace-with-a-local-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-local-refresh-secret-at-least-32-characters

R2_ACCOUNT_ID=replace-with-cloudflare-account-id
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET_NAME=responix-local
R2_PUBLIC_BASE_URL=https://example.r2.dev

OTEL_SERVICE_NAME=responix
LOG_LEVEL=info
