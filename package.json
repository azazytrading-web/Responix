{
  "name": "responix",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build --concurrency=1",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint --concurrency=1",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "turbo run typecheck --concurrency=1",
    "test": "turbo run test --concurrency=1",
    "prisma": "pnpm --dir packages/database exec prisma",
    "db:generate": "pnpm --filter @responix/database db:generate",
    "db:migrate": "pnpm --filter @responix/database db:migrate",
    "db:deploy": "pnpm --filter @responix/database db:deploy",
    "db:reset": "pnpm --filter @responix/database db:reset",
    "db:seed": "pnpm --filter @responix/database db:seed",
    "db:studio": "pnpm --filter @responix/database db:studio"
  },
  "devDependencies": {
    "@responix/config": "workspace:*",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
